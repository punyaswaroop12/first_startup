APP_NAME=AI Knowledge + Reporting Assistant
APP_ENV=development
API_V1_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
WEB_PORT=3000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ops_ai_assistant
JWT_SECRET_KEY=change-me-in-production-with-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_REQUESTS_PER_MINUTE=60
MAX_UPLOAD_SIZE_MB=15
FILE_STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=storage/uploads
EMAIL_PROVIDER=preview
EMAIL_PREVIEW_DIR=storage/emails
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
MAIL_FROM=ops-ai-assistant@example.com
MICROSOFT_OUTLOOK_SENDER=
TEAMS_PROVIDER=preview
TEAMS_PREVIEW_DIR=storage/teams
AI_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
MICROSOFT_AUTH_ENABLED=false
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=organizations
MICROSOFT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
MICROSOFT_GRAPH_SCOPE=https://graph.microsoft.com/.default
MICROSOFT_SCOPES=openid profile email User.Read
MICROSOFT_OAUTH_STATE_EXPIRE_MINUTES=10
MICROSOFT_ADMIN_EMAILS=
MICROSOFT_ADMIN_DOMAINS=
MICROSOFT_SYNC_PAGE_SIZE=100
MICROSOFT_DEFAULT_SYNC_FREQUENCY_MINUTES=1440
BACKGROUND_JOB_INLINE_EXECUTION=true
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
DEFAULT_ADMIN_EMAIL=admin@ops-ai-demo.example.com
DEFAULT_ADMIN_PASSWORD=AdminPass123!
DEFAULT_USER_EMAIL=analyst@ops-ai-demo.example.com
DEFAULT_USER_PASSWORD=UserPass123!
