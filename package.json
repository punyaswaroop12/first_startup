{
  "name": "ai-knowledge-reporting-assistant",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run api:dev\" \"npm run web:dev\"",
    "web:dev": "npm --workspace apps/web run dev",
    "web:build": "npm --workspace apps/web run build",
    "web:lint": "npm --workspace apps/web run lint",
    "web:typecheck": "npm --workspace apps/web run typecheck",
    "web:test": "npm --workspace apps/web run test",
    "api:dev": "cd apps/api && python3.12 -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "api:test": "cd apps/api && python3.12 -m pytest",
    "api:lint": "cd apps/api && python3.12 -m ruff check .",
    "api:format": "cd apps/api && python3.12 -m ruff format ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright": "^1.59.1"
  }
}
